# 数据库连接（换机器时主要改这里）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的密码
DB_NAME=mydate

# mydate SQL 备份目录（入库核验会扫描此目录下的 .sql 与 Excel）
SQL_DUMP_DIR=C:\Users\20711\Desktop\mydate

# PDF 文件根目录（与 std_filepath 表中的相对路径拼接）
PDF_ROOT=Z:\磁盘阵列
PDF_SUBDIR=标准文件下载

# Redis（批量入库 Worker 用，Web 工具可不填）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
